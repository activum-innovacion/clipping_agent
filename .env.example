# Activum Clipping Agent — Variables de entorno
# Local: copia este archivo como .env y rellena los valores reales
# GitHub Actions: añade estas mismas variables como Repository Secrets
#   en Settings → Secrets and variables → Actions → New repository secret

# API de Anthropic (obligatorio)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend — proveedor de email (obligatorio)
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Remitente verificado en Resend
# Mientras no tengas dominio verificado, usa EMAIL_FROM=onboarding@resend.dev
# (solo puede enviar al email asociado a tu cuenta Resend)
EMAIL_FROM=clipping@activum.com

# Destinatario(s). Una o varias direcciones separadas por coma.
EMAIL_TO=comunicacion@activum.com
