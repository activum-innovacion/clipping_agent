# Activum Clipping Agent — Variables de entorno
# Local: copia este archivo como .env y rellena los valores reales
# Vercel: añade estas mismas variables en Project Settings → Environment Variables

# API de Anthropic (obligatorio)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend — proveedor de email (obligatorio)
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Remitente verificado en Resend (debe pertenecer a un dominio verificado)
# Mientras no tengas dominio verificado, puedes probar enviándote a ti mismo
# con: EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM=clipping@activum.com

# Destinatario(s). Una o varias direcciones separadas por coma.
EMAIL_TO=comunicacion@activum.com

# Secret compartido entre Vercel Cron y el endpoint /api/clipping
# Generar con: openssl rand -hex 32
CRON_SECRET=cambia-esto-por-un-string-aleatorio-largo
